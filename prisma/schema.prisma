generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Comprador {
  id          String      @id
  name        String
  surname     String
  email       String      @unique
  rol         String      @default("BUYER")
  carritos    Carrito[]
  direcciones Direccion[]
}

model Direccion {
  id          String    @id @default(uuid())
  compradorId String
  calle       String
  altura      String
  ciudad      String
  cp          String
  esPrincipal Boolean   @default(true)
  comprador   Comprador @relation(fields: [compradorId], references: [id], onDelete: Cascade)
}

model Carrito {
  id          String        @id @default(uuid())
  compradorId String
  ultimaAct   DateTime      @updatedAt
  comprador   Comprador     @relation(fields: [compradorId], references: [id], onDelete: Cascade)
  items       ItemCarrito[]
}

model ItemCarrito {
  id        String  @id @default(uuid())
  carritoId String
  productId String
  cantidad  Int     @default(1)
  carrito   Carrito @relation(fields: [carritoId], references: [id], onDelete: Cascade)
}
